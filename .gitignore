# macOS
.DS_Store

# Runtime pane-id map (regenerated by barn.sh on every run)
.barn-panes

# Per-run state dir for an external target (Issue #2 escape hatch). A target project
# keeps a clean history; barn writes <target>/.mossy by absolute path. Matches any
# .mossy/ at any depth, including test targets nested in this repo. The dogfood run
# record (MISSION/GUARDRAILS/TICKS/CHRONICLE/ESCALATIONS) lives at the repo ROOT, not
# under .mossy/, so it stays tracked.
.mossy/

# Scratch / editor cruft
*.swp
*.tmp
