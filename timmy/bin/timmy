#!/usr/bin/env bash
# timmy - classify the state of a tmux pane running Claude Code, from outside.
# Vanilla bash + tmux. No third-party dependencies.
#
# v0 core (docs/smoke-test.md section 8): take two capture-pane snapshots a
# short interval apart. Identical => idle, differ => busy. This alone is a
# robust idle detector, independent of glyph specifics.
set -uo pipefail

# State -> exit code. Documented in --help; lets shell callers branch on $?.
readonly EXIT_IDLE=0
readonly EXIT_BUSY=10
readonly EXIT_WAITING=20
readonly EXIT_QUESTION=30

# Seconds between the two snapshots. Overridable for fast tests; the default
# matches the ~2s the smoke test used.
INTERVAL="${TIMMY_INTERVAL:-2}"

usage() {
  cat <<'EOF'
Usage: timmy --pane <pane-id> [--json]

Classify a tmux pane running Claude Code by taking two capture-pane snapshots
a short interval apart and comparing them.

Options:
  --pane <id>   tmux pane/target to inspect (e.g. %2, or a session name)
  --json        emit a JSON object with the state and the evidence used
  -h, --help    show this help

States and exit codes:
  idle           0    settled Claude box ("⏵⏵" mode line + empty "❯"), last
                      line not a '?'; or, if not a Claude box, identical snapshots
  busy          10    a spinner line is present, or (not a Claude box) snapshots
                      differ
  waiting-input 20    a numbered selection menu is shown
  question      30    idle box whose last assistant line ends in '?'

Environment:
  TIMMY_INTERVAL   seconds between the two snapshots (default: 2)
EOF
}

die() { printf 'timmy: %s\n' "$1" >&2; exit 64; }

pane=""
json=0
while [ $# -gt 0 ]; do
  case "$1" in
    --pane) shift; [ $# -gt 0 ] || die "--pane needs a value"; pane="$1" ;;
    --json) json=1 ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown argument: $1" ;;
  esac
  shift
done

[ -n "$pane" ] || die "--pane is required (see --help)"

snapshot() { tmux capture-pane -p -t "$pane"; }

# A working session shows a spinner line: the bullet glyph, a rotating gerund,
# and an ellipsis (smoke-test.md section 3, e.g. "● Whirring…"). The verb
# rotates, so we match the stable SHAPE, not any one word. LC_ALL=C keeps the
# match on the literal UTF-8 bytes regardless of the caller's locale.
has_spinner() { printf '%s\n' "$1" | LC_ALL=C grep -qE '●.*…'; }

# A selection menu (smoke-test.md section 9) is a numbered-option cursor line
# ("❯ 1.") together with an "Enter to confirm" affordance. Requiring both keeps
# stray prose mentioning either phrase from tripping the detector.
has_menu() {
  printf '%s\n' "$1" | LC_ALL=C grep -qE '❯ [0-9]' \
    && printf '%s\n' "$1" | grep -q 'Enter to confirm'
}

# A genuine Claude idle box (smoke-test.md section 2): an empty "❯" input line
# plus the "⏵⏵ ... (shift+tab to cycle)" mode line. We key on the "⏵⏵" marker,
# NOT the trailing "← for agents" suffix: that suffix is the FIRST thing to
# truncate on a narrow pane (verified live - at width 50 the mode line ends
# "...(shift+tab to cycle ·" with the suffix gone), whereas "⏵⏵" and "❯" are
# left-aligned and survive. The spinner check (above) already separates busy,
# so a settled "⏵⏵" box with no spinner is idle/question at any width.
is_idle_box() {
  # Claude renders the empty input line as "❯" + a U+00A0 NO-BREAK SPACE, which
  # grep's [[:space:]] does NOT reliably match (verified live). Normalise the
  # no-break space to a plain space in-shell (locale-independent) before testing.
  local nbsp=$'\xc2\xa0' text
  text="${1//$nbsp/ }"
  printf '%s\n' "$text" | LC_ALL=C grep -qE '^❯[[:space:]]*$' \
    && printf '%s\n' "$text" | LC_ALL=C grep -q '⏵⏵'
}

# Does the assistant's final message end in a question? Multi-line turns only
# prefix their FIRST line with "⏺"; the real closing line is often an indented
# CONTINUATION. So find the last non-blank CONTENT line, not the last "⏺" line.
# First drop the input box and status tail (everything from the empty "❯" down),
# then locate the closing content line two ways depending on the post-turn chrome:
#
#   TIMER PRESENT: cut above the "✻ ... for Ns" post-turn timer. The timer is a
#     reliable anchor - everything at or below it is chrome (the timer plus any
#     tip footer rendered beneath it), so the closing content line is the last
#     non-blank line ABOVE the timer.
#
#   TIMER GONE (turn fully settled): the timer vanishes but a tip/hint footer can
#     still linger directly above the box. With no anchor, walk up from the box
#     and STRIP footer chrome by its own signature - a "Tip:" line, or a hint
#     line carrying the " · " separator - rather than mistaking it for content.
#     Stop at the first non-chrome, non-blank line: that is the closing line.
#
# Then test whether THAT line ends in '?'. ("✻" = e2 9c bb, "·" = c2 b7.) The
# no-break space is normalised so the empty-box match is reliable. The timer
# regex is intentionally NOT widened here - unseen verb/format variants are a
# separate concern; this change only handles the timer's ABSENCE.
ends_in_question() {
  local nbsp=$'\xc2\xa0'
  printf '%s\n' "${1//$nbsp/ }" | LC_ALL=C awk '
    { line[NR] = $0 }
    END {
      box = 0
      for (i = NR; i >= 1; i--) if (line[i] ~ /^❯ *$/) { box = i; break }
      hi = (box > 0) ? box - 2 : NR

      timer = 0
      for (i = hi; i >= 1; i--) if (line[i] ~ /✻.*for [0-9]+s *$/) { timer = i; break }

      last = ""
      if (timer > 0) {
        for (i = timer - 1; i >= 1; i--) {
          s = line[i]; sub(/[ \t]+$/, "", s)
          if (s != "") { last = s; break }
        }
      } else {
        for (i = hi; i >= 1; i--) {
          s = line[i]; sub(/[ \t]+$/, "", s)
          t = s; sub(/^[ \t]+/, "", t)
          if (t == "") continue
          if (t ~ /^Tip:/) continue
          if (t ~ / · /) continue
          last = s; break
        }
      }
      exit (last ~ /\?$/) ? 0 : 1
    }
  '
}

snap1="$(snapshot)" || die "capture-pane failed for pane '$pane'"
sleep "$INTERVAL"
snap2="$(snapshot)" || die "capture-pane failed for pane '$pane'"

if [ "$snap1" = "$snap2" ]; then differ="false"; else differ="true"; fi
if has_spinner "$snap2"; then spinner="true"; else spinner="false"; fi
if has_menu "$snap2"; then menu="true"; else menu="false"; fi
if is_idle_box "$snap2"; then idle_box="true"; else idle_box="false"; fi
if ends_in_question "$snap2"; then ends_q="true"; else ends_q="false"; fi

# Precedence:
#   1. a menu asks for a choice            -> waiting-input
#   2. a spinner is present                -> busy
#   3. a genuine idle box (the "← for agents" suffix, present ONLY when idle)
#      is authoritative for the settled state, ABOVE the snapshot diff: a real
#      idle box can still show transient boot chrome that makes two snapshots
#      differ (proven against a live session), so the suffix overrides motion.
#      Inside it, a trailing "?" means question, else idle.
#   4. no suffix to trust -> fall back to the snapshot diff (idle detector for
#      panes we cannot positively identify): differ means busy, else idle.
if [ "$menu" = "true" ]; then
  state="waiting-input"; code="$EXIT_WAITING"
elif [ "$spinner" = "true" ]; then
  state="busy"; code="$EXIT_BUSY"
elif [ "$idle_box" = "true" ]; then
  if [ "$ends_q" = "true" ]; then
    state="question"; code="$EXIT_QUESTION"
  else
    state="idle"; code="$EXIT_IDLE"
  fi
elif [ "$differ" = "true" ]; then
  state="busy"; code="$EXIT_BUSY"
else
  state="idle"; code="$EXIT_IDLE"
fi

if [ "$json" -eq 1 ]; then
  printf '{"state":"%s","evidence":{"snapshots_differ":%s,"spinner":%s,"menu":%s,"idle_box":%s,"ends_in_question":%s,"interval":%s}}\n' \
    "$state" "$differ" "$spinner" "$menu" "$idle_box" "$ends_q" "$INTERVAL"
else
  printf '%s\n' "$state"
fi

exit "$code"
