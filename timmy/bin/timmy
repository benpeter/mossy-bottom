#!/usr/bin/env bash
# timmy - classify the state of a tmux pane running Claude Code, from outside.
# Vanilla bash + tmux. No third-party dependencies.
#
# v0 core (docs/smoke-test.md section 8): take two capture-pane snapshots a
# short interval apart. Identical => idle, differ => busy. This alone is a
# robust idle detector, independent of glyph specifics.
set -uo pipefail

# State -> exit code. Documented in --help; lets shell callers branch on $?.
readonly EXIT_IDLE=0
readonly EXIT_BUSY=10
readonly EXIT_WAITING=20
readonly EXIT_QUESTION=30
# --watch/--await: a snapshot failed mid-poll. Distinct from the per-state codes
# and from the usage error (64), so a caller can tell a dead pane apart.
readonly EXIT_WATCH_ERR=65
# --await only: the timeout elapsed with NO state change (a heartbeat). Distinct from
# the per-state codes, the usage error (64), and the capture error (65), so a caller
# can tell "nothing changed" from a real transition or a gone pane.
readonly EXIT_TIMEOUT=66

# Seconds between the two snapshots. Overridable for fast tests; the default
# matches the ~2s the smoke test used.
INTERVAL="${TIMMY_INTERVAL:-2}"

# Default --await heartbeat window in seconds; --timeout overrides it. Kept well above
# INTERVAL so a quiet pane is not woken needlessly; the shaun.md waker passes its own N.
AWAIT_TIMEOUT_DEFAULT=120

# #23: how many EXTRA snapshot pairs sustained_motion takes to confirm that an idle-box-shaped
# pane is genuinely working (not just showing a one-off transient). The motion must persist
# across all of them. 2 means "the initial diff plus 2 more consecutive diffs" - enough to
# outlast a brief boot-chrome flicker (the reason the box overrode motion pre-#23) while still
# catching a continuously advancing pane. The window costs SUSTAIN_SAMPLES*INTERVAL, paid ONLY
# in the rare idle_box-AND-differ case.
readonly SUSTAIN_SAMPLES=2

usage() {
  cat <<'EOF'
Usage: timmy --pane <pane-id> [--json]
       timmy --watch --pane <pane-id>
       timmy --await --pane <pane-id> [--timeout <secs>]

Classify a tmux pane running Claude Code by taking two capture-pane snapshots
a short interval apart and comparing them.

Options:
  --pane <id>       tmux pane/target to inspect (e.g. %2, or a session name)
  --json            emit a JSON object with the state and the evidence used
  --watch           poll the pane forever; print one line per state CHANGE only
  --await           block until the state changes once, then print it and exit
  --timeout <secs>  --await heartbeat window (default 120); 0 disables waiting
  -h, --help        show this help

States and exit codes (single-shot):
  idle           0    settled Claude box ("⏵⏵" mode line + empty "❯"), last
                      line not a '?'; or, if not a Claude box, identical snapshots
  busy          10    a spinner line is present, or (not a Claude box) snapshots
                      differ
  waiting-input 20    a numbered selection menu is shown
  question      30    idle box whose last assistant line ends in '?'

--watch mode:
  Prints "<state> <tick>" once on the first read, then one line each time the
  state CHANGES; stays silent while a state is held. The tick is a monotonic
  poll counter. Polls every TIMMY_INTERVAL seconds. Exits 0 on SIGINT/SIGTERM;
  exits 65 if a snapshot fails (e.g. the pane went away).

--await mode:
  Reads the start state (no output), then blocks until the state DIFFERS from it -
  prints the new state and exits with that state's code (0/10/20/30). If --timeout
  seconds pass with no change, prints the (unchanged) current state and exits 66 -
  a heartbeat the caller uses to re-anchor without a transition. Exits 0 on
  SIGINT/SIGTERM; exits 65 if a snapshot fails. Self-terminating: it exits on its
  own, so no process lingers after it returns.

Exit codes (multi-poll): 65 capture failed (gone pane), 66 --await timeout (no change).

Environment:
  TIMMY_INTERVAL   seconds between the two snapshots (default: 2)
EOF
}

die() { printf 'timmy: %s\n' "$1" >&2; exit 64; }

pane=""
json=0
watch=0
await=0
timeout="$AWAIT_TIMEOUT_DEFAULT"
while [ $# -gt 0 ]; do
  case "$1" in
    --pane) shift; [ $# -gt 0 ] || die "--pane needs a value"; pane="$1" ;;
    --json) json=1 ;;
    --watch) watch=1 ;;
    --await) await=1 ;;
    --timeout) shift; [ $# -gt 0 ] || die "--timeout needs a value"; timeout="$1" ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown argument: $1" ;;
  esac
  shift
done

[ -n "$pane" ] || die "--pane is required (see --help)"
case "$timeout" in
  ''|*[!0-9]*) die "--timeout needs a non-negative integer (seconds)" ;;
esac

snapshot() { tmux capture-pane -p -t "$pane"; }

# A working session shows an ACTIVE spinner LINE. We match its stable SHAPE
# (smoke-test.md section 3: "the stable cue is the shape"), NOT any one glyph or
# word, so the cue survives glyph rotation AND does not false-fire on content.
# The shape, anchored to line start:
#
#   <frame-glyph> <verb><ellipsis> ... (<live counter>)
#   e.g.  "● Whirring… (esc to interrupt · 1.2k tokens)"
#
#   - <frame-glyph>  one or more non-ASCII glyphs at line start ([^ -~], the
#                    complement of printable ASCII under LC_ALL=C). Covers ●, ✻, ✶,
#                    braille frames, and any future frame - glyph-agnostic. The ^
#                    anchor is what stops a ● bullet sitting MID-line in prose from
#                    matching (GAP-7): a content glyph is never the first thing on
#                    its line (it follows "- ", "| ", text, ...).
#   - <verb>         a single [A-Za-z]+ word, rotating freely (Whirring, Propagating,
#                    Cooked, ...) - verb-agnostic.
#   - <ellipsis>     the … glyph OR three ASCII dots ... - rendering-agnostic (GAP-1).
#                    Required IMMEDIATELY after the verb, so multi-word prose ending in
#                    an ellipsis ("Building the parser…") does NOT match.
#   - <live counter> a parenthesised elapsed/token counter carrying "esc" or a digit.
#                    This is what a finished/summary line lacks: "✻ Cooked for 5s" has
#                    no immediate ellipsis and no parens, so it reads idle (GAP-7).
#
# LC_ALL=C keeps the match on literal UTF-8 bytes regardless of the caller's locale.
#
# BOTTOM-ANCHOR (#10): the live spinner renders just above the input box, so we run the
# SHAPE match above (unchanged) over a SINGLE structurally-selected line, not the whole
# capture - so a spinner-shaped line higher in scrollback (a displayed report or diff that
# quotes a glyph) cannot SHADOW a real bottom state. This constrains WHERE the cue looks,
# never WHAT it matches, so the #9 shape gains (alt glyph, ASCII ellipsis, past-tense verb,
# narrow wrap) are preserved by construction - the matcher below is byte-identical.
#
# A fixed bottom-row count was too fragile (the first cut at this used K=6 and live-missed
# the STANDARD busy layout, whose spinner sits 7 rows up: spinner / blank / rule / prompt /
# rule / footerA / footerB). So we anchor STRUCTURALLY on the real input box instead:
#   - Find the bottom-most RULE-FENCED prompt: a "^❯" line whose first non-blank line above
#     is a "───" rule (the box's top fence). The fence is what makes it the REAL input box,
#     not a menu cursor ("❯ 1.") or a "❯" quoted in displayed content - those have no rule
#     above them, so they are not mistaken for the prompt.
#   - Walk UP from the top fence, skipping ONLY blank lines and "───" rules, and take the
#     first line that is neither. That candidate is the live status line - the spinner when
#     working, the closing content line otherwise. No footer/mode-wording dependency, so no
#     #9/#10-class drift.
#   - No rule-fenced prompt visible (a streaming pane, or a synthetic fixture with no box,
#     or a working pane displaying menu source): fall back to the last non-blank line, where
#     a live spinner renders.
# The candidate (one line) is then tested by the exact #9 matcher.
#
# Residual for a later slice (no fixture exercises it): a decoy spinner sitting IMMEDIATELY
# above the box fence with NO content between is structurally identical to a real spinner
# and still fires. Closing that needs the input-region distinction the idle-box slice adds.
has_spinner() {
  printf '%s\n' "$1" \
    | LC_ALL=C awk '
        { line[NR] = $0 }
        END {
          last = NR; while (last > 0 && line[last] ~ /^[ \t]*$/) last--
          if (last == 0) exit
          prompt = 0
          for (i = last; i >= 1; i--) {
            if (line[i] !~ /^[ \t]*❯/) continue
            j = i - 1; while (j >= 1 && line[j] ~ /^[ \t]*$/) j--
            if (j >= 1 && line[j] ~ /───/) { prompt = i; break }
          }
          cand = 0
          if (prompt > 0) {
            for (i = prompt - 1; i >= 1; i--) {
              if (line[i] ~ /^[ \t]*$/) continue
              if (line[i] ~ /───/) continue
              cand = i; break
            }
          } else {
            cand = last
          }
          if (cand > 0) print line[cand]
        }' \
    | LC_ALL=C grep -qE '^[[:space:]]*[^ -~]+ +[A-Za-z]+(…|\.\.\.).*\([^)]*(esc|[0-9])'
}

# A selection menu (smoke-test.md sections 1 and 9) is a NUMBERED OPTION LIST with a
# cursor on one option:
#   ❯ 1. Yes, I trust this folder
#     2. No, exit
#    Enter to confirm · Esc to cancel      <- affordance: wraps/varies, NOT relied on
# We match the stable STRUCTURAL shape - a "❯ <n>" cursor line PLUS at least two
# numbered-option lines at line start - NOT the "Enter to confirm" affordance, which
# truncates mid-phrase on a narrow pane (GAP-2) and varies or is absent across menus
# (GAP-3). Short cursor/option lines stay left-aligned and survive wrapping, so the
# shape holds where the phrase does not.
#
# Menu-like TEXT in displayed content (source, a quoted menu) shares this shape. Classifier
# PRECEDENCE (spinner, idle box, and diff decided BEFORE menu) masks it when the real bottom
# is working or a settled box - but the cue itself should not fire on a scrollback quote.
#
# BOTTOM-ANCHOR (#10): the live menu IS the bottom input region (it replaces the input box),
# so below its bottom-most option there is only its affordance and blanks - NEVER a
# real-bottom structure. We keep the #9 shape matcher byte-identical (the two greps below),
# then add a gate: if any real-bottom structure - a "───" rule, an empty "❯" box, a
# footer/mode line, a "⏺" turn, or a spinner - sits below the bottom-most numbered option,
# those options are a scrollback QUOTE (the real state renders below them), so reject. A
# live menu has no such structure below it. This closes the GAP-2 residual: a frozen
# numbered list in scrollback above a different real bottom state no longer reads as a menu.
# The no-break space is normalised as elsewhere; LC_ALL=C matches literal bytes.
has_menu() {
  local nbsp=$'\xc2\xa0' text opts
  text="${1//$nbsp/ }"
  # #9 shape matcher, UNCHANGED: a "❯ <n>" cursor plus >= 2 numbered-option lines.
  printf '%s\n' "$text" | LC_ALL=C grep -qE '^[[:space:]]*❯[[:space:]]+[0-9]' || return 1
  opts="$(printf '%s\n' "$text" | LC_ALL=C grep -cE '^[[:space:]]*(❯[[:space:]]+)?[0-9][.)]')"
  [ "$opts" -ge 2 ] || return 1
  # bottom-anchor gate: no real-bottom structure below the bottom-most numbered option.
  printf '%s\n' "$text" | LC_ALL=C awk '
    { line[NR] = $0 }
    function isbottomstruct(s) {
      return (s ~ /───/ || s ~ /^❯[ \t]*$/ || s ~ /⏵⏵|shift\+tab|for agents/ \
        || s ~ /^[ \t]*⏺/ \
        || s ~ /^[[:space:]]*[^ -~]+ +[A-Za-z]+(…|\.\.\.).*\([^)]*(esc|[0-9])/)
    }
    END {
      last = NR; while (last > 0 && line[last] ~ /^[ \t]*$/) last--
      bo = 0; for (i = last; i >= 1; i--) if (line[i] ~ /^[ \t]*(❯[ \t]+)?[0-9][.)]/) { bo = i; break }
      if (bo == 0) exit 1
      for (k = bo + 1; k <= last; k++) if (isbottomstruct(line[k])) exit 1
      exit 0
    }'
}

# A genuine Claude idle box (smoke-test.md section 2): an empty "❯" input line fenced by
# "─" rules, with a footer/mode line below it. The empty "❯" is the MOST stable cue, but
# an empty "❯" also appears in displayed CONTENT (a quoted box in scrollback), and the old
# any-empty-"❯"-anywhere test let such a quote SHADOW the real bottom state - so a real
# menu (or diff-busy) below a quoted box read idle (#10, reproduced live).
#
# BOTTOM-ANCHOR (#10): the live input box renders at the bottom, so we recognise it only
# THERE. The box is the bottom-most empty "❯" that is (a) rule-fenced - its first non-blank
# line above is a "───" rule - and (b) has no COMPETING bottom structure below it to the
# bottom. A quoted box in scrollback fails this: its "❯" is INDENTED (not "^❯"), so it is
# never picked as the box; and any real bottom state below a column-0 "❯" trips (b). A real
# box passes both. The "───" fence IS the GAP-6 corroborator, so a box with a changed or
# absent "⏵⏵" marker is still recognised by its rule fence. This fires for BOTH idle and
# working panes (both render the input box); distinguishing those is the spinner's job, so
# spinner stays precedence step 1 - this anchor only stops a SCROLLBACK quote from firing.
#
# NARROW-ROBUST (#22, the #17 residual): check (b) was a WHITELIST - every line below the
# box had to match a known box-chrome keyword. At narrow width tmux WRAPS the footer into
# continuation fragments ("xt: 5%" from "Context: 5%", "agents" from "← for agents") that
# carry no keyword, so the whitelist dropped a perfectly real box and idle/question
# classification failed. (b) is now a BLACKLIST: the live input box is the bottom-most UI
# element, so below it sit only its bottom rule fence and the footer (wrapped freely) -
# NEVER a competing bottom structure. We reject ONLY on a competing structure - a live menu
# cursor, an assistant turn glyph, or a spinner line - which would prove the "❯" we found
# is not the live box. A wrapped footer fragment is none of those, so the box now survives
# any width. This widens (b)'s tolerance without weakening the #10 shadow rejection: the
# column-0 anchor (a quoted box's "❯" is indented) already carries that, and a real bottom
# state below a column-0 "❯" still trips the blacklist.
is_idle_box() {
  # Claude renders the empty input line as "❯" + a U+00A0 NO-BREAK SPACE, which grep's
  # [[:space:]] does NOT reliably match (verified live). Normalise it to a plain space.
  local nbsp=$'\xc2\xa0' text
  text="${1//$nbsp/ }"
  printf '%s\n' "$text" | LC_ALL=C awk '
    { line[NR] = $0 }
    # A competing bottom structure below the "❯": real content the live input box never has
    # beneath it. Footer text (incl. width-wrapped fragments) and rules are NOT competing.
    function competes(s) {
      return (s ~ /^❯[ \t]+[0-9]/ \
        || s ~ /^[ \t]*⏺/ \
        || s ~ /^[[:space:]]*[^ -~]+ +[A-Za-z]+(…|\.\.\.).*\([^)]*(esc|[0-9])/)
    }
    END {
      last = NR; while (last > 0 && line[last] ~ /^[ \t]*$/) last--
      if (last == 0) exit 1
      # bottom-most empty prompt
      box = 0
      for (i = last; i >= 1; i--) if (line[i] ~ /^❯[ \t]*$/) { box = i; break }
      if (box == 0) exit 1
      # (a) rule-fenced: first non-blank line above is a ─── rule
      j = box - 1; while (j >= 1 && line[j] ~ /^[ \t]*$/) j--
      if (j < 1 || line[j] !~ /───/) exit 1
      # (b) no competing bottom structure below it (a quoted box has real content below)
      for (k = box + 1; k <= last; k++) if (competes(line[k])) exit 1
      exit 0
    }'
}

# A SETTLED-idle box, distinguished from a WORKING one (#17). is_idle_box fires true for
# BOTH an idle pane and a mid-turn working pane - both render the same rule-fenced empty
# "❯" box - so its only discriminator is the spinner. That fails the decoy case: a real
# idle box with a stale/decoy spinner-shaped line just above its top fence reads BUSY
# (false-positive busy -> shaun never hands work -> the chain stalls).
#
# The discriminator is the mode-line suffix "← for agents" (smoke-test.md sections 2/3/8):
# it is PRESENT when the pane is settled-idle and ABSENT while working. Because it is
# structurally absent during work, "suffix present => settled idle" can NEVER false-negative
# a working pane (the binding safety criterion) - the dangerous direction is not introduced.
#
# POSITION-ANCHORED exactly like is_idle_box (the #10 discipline): the suffix is required in
# the box-chrome BELOW the bottom-most rule-fenced empty "❯" box, so a "← for agents" sitting
# in a SCROLLBACK-quoted idle box (whose "❯" is indented, not "^❯", and which has real content
# below it) cannot trigger it. This is is_idle_box's structure PLUS one requirement: the
# footer carries the suffix - so a true result implies is_idle_box is also true.
#
# WIDE-PANE-ONLY by nature: the suffix is the first thing to truncate on a narrow pane
# (verified: "...(shift+tab to cycle ·"). When it is absent - working OR narrow-truncated -
# this returns false and the caller falls through to the existing spinner/precedence logic
# unchanged. The narrow decoy thus stays false-positive-busy, the SAFE direction (a stall,
# never a working pane mislabeled idle); there is no criterion-safe narrow signal in the
# capture today, so narrow is left as the open question rather than risk the dangerous miss.
has_idle_suffix() {
  local nbsp=$'\xc2\xa0' text
  text="${1//$nbsp/ }"
  printf '%s\n' "$text" | LC_ALL=C awk '
    { line[NR] = $0 }
    function isboxchrome(s) {
      return (s ~ /^[ \t]*$/ || s ~ /───/ \
        || s ~ /⏵⏵|shift\+tab|for agents|bypass permissions|Context|Ctx/ || s ~ / \| /)
    }
    END {
      last = NR; while (last > 0 && line[last] ~ /^[ \t]*$/) last--
      if (last == 0) exit 1
      box = 0
      for (i = last; i >= 1; i--) if (line[i] ~ /^❯[ \t]*$/) { box = i; break }
      if (box == 0) exit 1
      j = box - 1; while (j >= 1 && line[j] ~ /^[ \t]*$/) j--
      if (j < 1 || line[j] !~ /───/) exit 1
      found = 0
      for (k = box + 1; k <= last; k++) {
        if (!isboxchrome(line[k])) exit 1
        if (line[k] ~ /← for agents/) found = 1
      }
      exit (found ? 0 : 1)
    }'
}

# Does the assistant's final message end in a question? Multi-line turns only prefix
# their FIRST line with "⏺"; the real closing line is often an indented CONTINUATION.
# We anchor on the SHAPE of a turn, not on the post-turn timer's exact glyph/wording:
#
#   1. Find the input box (the empty "❯" line). Everything at/below it is box chrome.
#   2. Find the last "⏺" above the box - the start of the last assistant turn.
#   3. Scan DOWN from that "⏺", stopping at the first CHROME line; the closing content
#      line is the last non-blank line before it. Chrome is matched by SHAPE, so this
#      survives timer drift and narrow-pane wrap:
#        - a "───" rule fence
#        - a "Tip:" footer
#        - a key-hint footer (esc to interrupt / shift+tab / ctrl+ / to show todos /
#          to cycle / for agents)
#        - a post-turn TIMER/STATUS line: a glyph-led line (leading non-ASCII glyph
#          that is NOT the "⏺" content prefix) carrying an elapsed token [0-9][smh].
#          This is glyph-agnostic (GAP-5: a changed "✻" still matches) and NOT anchored
#          to the line end (GAP-4: a wrapped trailing hint after "for Ns" still matches).
#      A line is NOT chrome merely because it contains a "·" (GAP-8): a genuine closing
#      question may use "·", so we strip only by the signatures above, never by "·".
#   4. If there is no "⏺" (turn scrolled off), fall back to: walk UP from the box,
#      skip blanks and chrome, take the first content line.
#
# Then test whether the closing line ends in "?". The no-break space is normalised so
# the empty-box match is reliable. Adversarial chrome (a "Tip: ...?" footer, a hint
# line) is stripped by signature and so never fabricates a question.
ends_in_question() {
  local nbsp=$'\xc2\xa0'
  printf '%s\n' "${1//$nbsp/ }" | LC_ALL=C awk '
    { line[NR] = $0 }
    function trim(s) { sub(/^[ \t]+/, "", s); sub(/[ \t]+$/, "", s); return s }
    function ischrome(s,   t) {
      t = trim(s)
      if (t ~ /^───/) return 1
      if (t ~ /^Tip:/) return 1
      if (t ~ /esc to interrupt|shift\+tab|ctrl\+|to show todos|to cycle|for agents/) return 1
      if (t ~ /^[^ -~]/ && t !~ /^⏺/ && t ~ /[0-9][smh]/) return 1
      # A hint footer joins its key/action pairs with "·", whatever the specific words, and
      # never ends in "?". So a "·"-bearing line that is NOT a question is a footer - this
      # catches a reworded/timer-gone key-hint footer without depending on its wording, while
      # a genuine "·"-bearing question (GAP-8) ends in "?" and is kept as content.
      if (t ~ /·/ && t !~ /\?$/) return 1
      return 0
    }
    END {
      box = 0
      for (i = NR; i >= 1; i--) if (line[i] ~ /^❯ *$/) { box = i; break }
      hi = (box > 0) ? box - 1 : NR

      turn = 0
      for (i = hi; i >= 1; i--) if (line[i] ~ /^[ \t]*⏺/) { turn = i; break }

      last = ""
      if (turn > 0) {
        end = hi
        for (i = turn; i <= hi; i++) if (ischrome(line[i])) { end = i - 1; break }
        for (i = end; i >= turn; i--) if (trim(line[i]) != "") { last = line[i]; break }
      } else {
        for (i = hi; i >= 1; i--) {
          if (trim(line[i]) == "") continue
          if (ischrome(line[i])) continue
          last = line[i]; break
        }
      }
      sub(/[ \t]+$/, "", last)
      exit (last ~ /\?$/) ? 0 : 1
    }
  '
}

# sustained_motion - confirm an idle-box-shaped pane is GENUINELY working, not just showing a
# one-off transient (#23). is_idle_box fires for BOTH a settled idle box and a working pane
# that merely renders idle-box chrome (a quoted box, the worker's own fixtures); when such a
# pane is ALSO advancing (snapshots differ), trusting the bare box shape as "settled" is the
# #23 false-idle - a still-working worker read as finished, the DANGEROUS direction (a driver
# treats it as done). But a SINGLE diff is not enough to overrule the box: a real idle box can
# show transient boot chrome that differs once then settles - exactly why the box overrode
# motion before #23. So we require the motion to PERSIST: take SUSTAIN_SAMPLES more snapshot
# pairs and return 0 (sustained -> working) only if EVERY consecutive pair differs; return 1
# (settled -> trust the box) the moment any consecutive pair matches, i.e. the churn stopped.
# A capture failure in the window returns 1 (settled), preserving the pre-#23 behavior (the box
# decides) rather than inventing a new error path - classify_once already handles a gone pane
# on its own two snapshots before this is ever reached.
sustained_motion() {
  local prev cur n
  prev="$(snapshot)" || return 1
  for ((n = 0; n < SUSTAIN_SAMPLES; n++)); do
    sleep "$INTERVAL"
    cur="$(snapshot)" || return 1
    [ "$prev" = "$cur" ] && return 1
    prev="$cur"
  done
  return 0
}

# Take one fresh pair of snapshots and classify them. Sets the globals `state`,
# `code`, and the evidence vars (differ/spinner/menu/idle_box/sustained/ends_q). Returns
# nonzero if a capture fails. Both the single-shot path and --watch call THIS, so
# the two modes can never drift apart - there is one classifier, not two.
#
# Precedence (liveness is decided BEFORE the menu shape, which is how menu-like text in
# displayed content is kept from firing - GAP-2/3 false-positive, hit live at 14:17):
#   0. a SETTLED-idle box (#17): the bottom input box's mode line carries the "← for agents"
#      suffix, which is present only when idle and absent while working. This is decided
#      BEFORE the spinner, so a decoy/stale spinner-shaped line above a real idle box no
#      longer reads busy. It can never false-negative a working pane, because a working
#      pane never renders the suffix; when the suffix is absent (working OR narrow-pane
#      truncated) this is skipped and the spinner/precedence below decides unchanged.
#      Inside it, a trailing "?" means question, else idle.
#   1. a spinner is present                -> busy. A working pane is never a menu, so
#      this is checked first; it vetoes a menu shape sitting in the working pane's text.
#   2. a genuine idle box (the "⏵⏵" mode marker + empty "❯") is authoritative for the
#      settled state, ABOVE a SINGLE snapshot diff: a real idle box can still show transient
#      boot chrome that makes two snapshots differ (proven against a live session), so the box
#      overrides a one-off diff. BUT if the diff is PERSISTENT (sustained_motion confirms the
#      pane keeps advancing), the box is just chrome on a genuinely working pane (#23) and
#      liveness wins -> busy. This closes the #22 decoy residual without flipping a settled box
#      or a transient boot flicker to busy: only PERSISTENT motion overrides the box. A live
#      menu has no empty "❯" (its "❯" carries an option number), so a settled box and a menu
#      are mutually exclusive. With no sustained motion, a trailing "?" means question, else idle.
#   3. the snapshots differ                -> busy. An advancing pane is working, not a
#      static menu; deciding this before menu stops streamed numbered-list content from
#      reading as a menu. A real selection menu waits for input, so it is static here.
#   4. a numbered-option menu shape         -> waiting-input. Reached only when the pane
#      is static, not working, and not a settled box - i.e. a genuine live menu.
#   5. nothing to trust                     -> idle (the snapshot-diff idle case).
classify_once() {
  local snap1 snap2
  snap1="$(snapshot)" || return 1
  sleep "$INTERVAL"
  snap2="$(snapshot)" || return 1

  if [ "$snap1" = "$snap2" ]; then differ="false"; else differ="true"; fi
  if has_spinner "$snap2"; then spinner="true"; else spinner="false"; fi
  if has_menu "$snap2"; then menu="true"; else menu="false"; fi
  if is_idle_box "$snap2"; then idle_box="true"; else idle_box="false"; fi
  if has_idle_suffix "$snap2"; then idle_suffix="true"; else idle_suffix="false"; fi
  if ends_in_question "$snap2"; then ends_q="true"; else ends_q="false"; fi
  sustained="false"  # set true only when the idle_box+differ branch confirms persistent motion

  if [ "$idle_suffix" = "true" ]; then
    # settled-idle box confirmed by the "← for agents" suffix: beats the spinner, closing
    # the decoy-above-the-box case. A working pane never shows the suffix, so this branch
    # cannot mislabel a working pane idle.
    if [ "$ends_q" = "true" ]; then
      state="question"; code="$EXIT_QUESTION"
    else
      state="idle"; code="$EXIT_IDLE"
    fi
  elif [ "$spinner" = "true" ]; then
    state="busy"; code="$EXIT_BUSY"
  elif [ "$idle_box" = "true" ]; then
    # #23: the box shape fires for an idle box AND a working pane that renders idle-box
    # chrome. If the pane is PERSISTENTLY advancing, it is the latter - liveness overrules
    # the box -> busy. sustained_motion is called ONLY here (idle_box AND a diff), so a
    # static box pays nothing, and a one-off boot-chrome diff settles -> stays idle.
    if [ "$differ" = "true" ] && sustained_motion; then
      sustained="true"; state="busy"; code="$EXIT_BUSY"
    elif [ "$ends_q" = "true" ]; then
      state="question"; code="$EXIT_QUESTION"
    else
      state="idle"; code="$EXIT_IDLE"
    fi
  elif [ "$differ" = "true" ]; then
    state="busy"; code="$EXIT_BUSY"
  elif [ "$menu" = "true" ]; then
    state="waiting-input"; code="$EXIT_WAITING"
  else
    state="idle"; code="$EXIT_IDLE"
  fi
}

# --watch: poll the pane and print one line per state CHANGE. Emit the first
# read, then stay silent while the state holds. SIGINT/SIGTERM is a clean stop
# (exit 0) - the same trap/exit run_await uses. SIGPIPE is folded into that same
# trap: when a consumer closes the pipe, the next write would otherwise kill the
# process by signal 13 (the linger-then-die mode hit during the #4 gate); the trap
# turns it into a clean exit 0 instead. A failed snapshot - a pane that went away
# mid-watch - makes classify_once return nonzero, and we exit EXIT_WATCH_ERR, the
# same constant single-shot and --await use, so the modes cannot drift. (A silent
# watcher cannot notice a dead reader until its next write; for a consumer that must
# never linger, use --await, which self-terminates.)
run_watch() {
  trap 'exit 0' INT TERM PIPE
  local last="" tick=0
  while :; do
    if ! classify_once; then
      printf 'timmy: capture-pane failed for pane %s\n' "$pane" >&2
      exit "$EXIT_WATCH_ERR"
    fi
    if [ "$state" != "$last" ]; then
      printf '%s %d\n' "$state" "$tick"
      last="$state"
    fi
    tick=$((tick + 1))
  done
}

# --await: read the start state (no output), then block until the state DIFFERS from
# it - print the new state and exit with its code. If --timeout seconds elapse with no
# change, print the (unchanged) current state and exit EXIT_TIMEOUT (a heartbeat). Both
# the start read and each poll call classify_once, so await never drifts from the other
# modes. SIGINT/SIGTERM is a clean stop (exit 0); a failed snapshot exits EXIT_WATCH_ERR.
# Self-terminating - it returns on its own, so nothing lingers (unlike --watch).
run_await() {
  trap 'exit 0' INT TERM
  if ! classify_once; then
    printf 'timmy: capture-pane failed for pane %s\n' "$pane" >&2
    exit "$EXIT_WATCH_ERR"
  fi
  local start_state="$state"
  SECONDS=0
  while [ "$SECONDS" -lt "$timeout" ]; do
    if ! classify_once; then
      printf 'timmy: capture-pane failed for pane %s\n' "$pane" >&2
      exit "$EXIT_WATCH_ERR"
    fi
    if [ "$state" != "$start_state" ]; then
      printf '%s\n' "$state"
      exit "$code"
    fi
  done
  printf '%s\n' "$state"
  exit "$EXIT_TIMEOUT"
}

if [ "$watch" -eq 1 ]; then
  run_watch   # loops until a signal or a capture error; never returns
fi

if [ "$await" -eq 1 ]; then
  run_await   # returns on the first change or at the timeout; never lingers
fi

classify_once || die "capture-pane failed for pane '$pane'"

if [ "$json" -eq 1 ]; then
  printf '{"state":"%s","evidence":{"snapshots_differ":%s,"spinner":%s,"menu":%s,"idle_box":%s,"idle_suffix":%s,"sustained_motion":%s,"ends_in_question":%s,"interval":%s}}\n' \
    "$state" "$differ" "$spinner" "$menu" "$idle_box" "$idle_suffix" "$sustained" "$ends_q" "$INTERVAL"
else
  printf '%s\n' "$state"
fi

exit "$code"
