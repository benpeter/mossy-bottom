#!/usr/bin/env bash
# timmy - classify the state of a tmux pane running Claude Code, from outside.
# Vanilla bash + tmux. No third-party dependencies.
#
# v0 core (docs/smoke-test.md section 8): take two capture-pane snapshots a
# short interval apart. Identical => idle, differ => busy. This alone is a
# robust idle detector, independent of glyph specifics.
set -uo pipefail

# State -> exit code. Documented in --help; lets shell callers branch on $?.
readonly EXIT_IDLE=0
readonly EXIT_BUSY=10
readonly EXIT_WAITING=20
readonly EXIT_QUESTION=30
# --watch/--await: a snapshot failed mid-poll. Distinct from the per-state codes
# and from the usage error (64), so a caller can tell a dead pane apart.
readonly EXIT_WATCH_ERR=65
# --await only: the timeout elapsed with NO state change (a heartbeat). Distinct from
# the per-state codes, the usage error (64), and the capture error (65), so a caller
# can tell "nothing changed" from a real transition or a gone pane.
readonly EXIT_TIMEOUT=66

# Seconds between the two snapshots. Overridable for fast tests; the default
# matches the ~2s the smoke test used.
INTERVAL="${TIMMY_INTERVAL:-2}"

# Default --await heartbeat window in seconds; --timeout overrides it. Kept well above
# INTERVAL so a quiet pane is not woken needlessly; the shaun.md waker passes its own N.
AWAIT_TIMEOUT_DEFAULT=120

usage() {
  cat <<'EOF'
Usage: timmy --pane <pane-id> [--json]
       timmy --watch --pane <pane-id>
       timmy --await --pane <pane-id> [--timeout <secs>]

Classify a tmux pane running Claude Code by taking two capture-pane snapshots
a short interval apart and comparing them.

Options:
  --pane <id>       tmux pane/target to inspect (e.g. %2, or a session name)
  --json            emit a JSON object with the state and the evidence used
  --watch           poll the pane forever; print one line per state CHANGE only
  --await           block until the state changes once, then print it and exit
  --timeout <secs>  --await heartbeat window (default 120); 0 disables waiting
  -h, --help        show this help

States and exit codes (single-shot):
  idle           0    settled Claude box ("⏵⏵" mode line + empty "❯"), last
                      line not a '?'; or, if not a Claude box, identical snapshots
  busy          10    a spinner line is present, or (not a Claude box) snapshots
                      differ
  waiting-input 20    a numbered selection menu is shown
  question      30    idle box whose last assistant line ends in '?'

--watch mode:
  Prints "<state> <tick>" once on the first read, then one line each time the
  state CHANGES; stays silent while a state is held. The tick is a monotonic
  poll counter. Polls every TIMMY_INTERVAL seconds. Exits 0 on SIGINT/SIGTERM;
  exits 65 if a snapshot fails (e.g. the pane went away).

--await mode:
  Reads the start state (no output), then blocks until the state DIFFERS from it -
  prints the new state and exits with that state's code (0/10/20/30). If --timeout
  seconds pass with no change, prints the (unchanged) current state and exits 66 -
  a heartbeat the caller uses to re-anchor without a transition. Exits 0 on
  SIGINT/SIGTERM; exits 65 if a snapshot fails. Self-terminating: it exits on its
  own, so no process lingers after it returns.

Exit codes (multi-poll): 65 capture failed (gone pane), 66 --await timeout (no change).

Environment:
  TIMMY_INTERVAL   seconds between the two snapshots (default: 2)
EOF
}

die() { printf 'timmy: %s\n' "$1" >&2; exit 64; }

pane=""
json=0
watch=0
await=0
timeout="$AWAIT_TIMEOUT_DEFAULT"
while [ $# -gt 0 ]; do
  case "$1" in
    --pane) shift; [ $# -gt 0 ] || die "--pane needs a value"; pane="$1" ;;
    --json) json=1 ;;
    --watch) watch=1 ;;
    --await) await=1 ;;
    --timeout) shift; [ $# -gt 0 ] || die "--timeout needs a value"; timeout="$1" ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown argument: $1" ;;
  esac
  shift
done

[ -n "$pane" ] || die "--pane is required (see --help)"
case "$timeout" in
  ''|*[!0-9]*) die "--timeout needs a non-negative integer (seconds)" ;;
esac

snapshot() { tmux capture-pane -p -t "$pane"; }

# A working session shows an ACTIVE spinner LINE. We match its stable SHAPE
# (smoke-test.md section 3: "the stable cue is the shape"), NOT any one glyph or
# word, so the cue survives glyph rotation AND does not false-fire on content.
# The shape, anchored to line start:
#
#   <frame-glyph> <verb><ellipsis> ... (<live counter>)
#   e.g.  "● Whirring… (esc to interrupt · 1.2k tokens)"
#
#   - <frame-glyph>  one or more non-ASCII glyphs at line start ([^ -~], the
#                    complement of printable ASCII under LC_ALL=C). Covers ●, ✻, ✶,
#                    braille frames, and any future frame - glyph-agnostic. The ^
#                    anchor is what stops a ● bullet sitting MID-line in prose from
#                    matching (GAP-7): a content glyph is never the first thing on
#                    its line (it follows "- ", "| ", text, ...).
#   - <verb>         a single [A-Za-z]+ word, rotating freely (Whirring, Propagating,
#                    Cooked, ...) - verb-agnostic.
#   - <ellipsis>     the … glyph OR three ASCII dots ... - rendering-agnostic (GAP-1).
#                    Required IMMEDIATELY after the verb, so multi-word prose ending in
#                    an ellipsis ("Building the parser…") does NOT match.
#   - <live counter> a parenthesised elapsed/token counter carrying "esc" or a digit.
#                    This is what a finished/summary line lacks: "✻ Cooked for 5s" has
#                    no immediate ellipsis and no parens, so it reads idle (GAP-7).
#
# LC_ALL=C keeps the match on literal UTF-8 bytes regardless of the caller's locale.
has_spinner() {
  printf '%s\n' "$1" | LC_ALL=C grep -qE \
    '^[[:space:]]*[^ -~]+ +[A-Za-z]+(…|\.\.\.).*\([^)]*(esc|[0-9])'
}

# A selection menu (smoke-test.md sections 1 and 9) is a NUMBERED OPTION LIST with a
# cursor on one option:
#   ❯ 1. Yes, I trust this folder
#     2. No, exit
#    Enter to confirm · Esc to cancel      <- affordance: wraps/varies, NOT relied on
# We match the stable STRUCTURAL shape - a "❯ <n>" cursor line PLUS at least two
# numbered-option lines at line start - NOT the "Enter to confirm" affordance, which
# truncates mid-phrase on a narrow pane (GAP-2) and varies or is absent across menus
# (GAP-3). Short cursor/option lines stay left-aligned and survive wrapping, so the
# shape holds where the phrase does not.
#
# Menu-like TEXT in displayed content (source, a quoted menu) shares this shape, so the
# false-positive guard is NOT here - it is classifier PRECEDENCE: an active spinner, a
# settled idle box, and an advancing diff are all decided BEFORE menu, so this fires
# only when the pane is genuinely static, not working, and not a settled box - which is
# exactly a live menu (its "❯" carries an option number, so it is never the empty idle
# box). The no-break space is normalised as elsewhere; LC_ALL=C matches literal bytes.
has_menu() {
  local nbsp=$'\xc2\xa0' text opts
  text="${1//$nbsp/ }"
  printf '%s\n' "$text" | LC_ALL=C grep -qE '^[[:space:]]*❯[[:space:]]+[0-9]' || return 1
  opts="$(printf '%s\n' "$text" | LC_ALL=C grep -cE '^[[:space:]]*(❯[[:space:]]+)?[0-9][.)]')"
  [ "$opts" -ge 2 ]
}

# A genuine Claude idle box (smoke-test.md section 2): an empty "❯" input line
# plus the "⏵⏵ ... (shift+tab to cycle)" mode line. We key on the "⏵⏵" marker,
# NOT the trailing "← for agents" suffix: that suffix is the FIRST thing to
# truncate on a narrow pane (verified live - at width 50 the mode line ends
# "...(shift+tab to cycle ·" with the suffix gone), whereas "⏵⏵" and "❯" are
# left-aligned and survive. The spinner check (above) already separates busy,
# so a settled "⏵⏵" box with no spinner is idle/question at any width.
is_idle_box() {
  # Claude renders the empty input line as "❯" + a U+00A0 NO-BREAK SPACE, which
  # grep's [[:space:]] does NOT reliably match (verified live). Normalise the
  # no-break space to a plain space in-shell (locale-independent) before testing.
  local nbsp=$'\xc2\xa0' text
  text="${1//$nbsp/ }"
  printf '%s\n' "$text" | LC_ALL=C grep -qE '^❯[[:space:]]*$' \
    && printf '%s\n' "$text" | LC_ALL=C grep -q '⏵⏵'
}

# Does the assistant's final message end in a question? Multi-line turns only
# prefix their FIRST line with "⏺"; the real closing line is often an indented
# CONTINUATION. So find the last non-blank CONTENT line, not the last "⏺" line.
# First drop the input box and status tail (everything from the empty "❯" down),
# then locate the closing content line two ways depending on the post-turn chrome:
#
#   TIMER PRESENT: cut above the "✻ ... for Ns" post-turn timer. The timer is a
#     reliable anchor - everything at or below it is chrome (the timer plus any
#     tip footer rendered beneath it), so the closing content line is the last
#     non-blank line ABOVE the timer.
#
#   TIMER GONE (turn fully settled): the timer vanishes but a tip/hint footer can
#     still linger directly above the box. With no anchor, walk up from the box
#     and STRIP footer chrome by its own signature - a "Tip:" line, or a hint
#     line carrying the " · " separator - rather than mistaking it for content.
#     Stop at the first non-chrome, non-blank line: that is the closing line.
#
# Then test whether THAT line ends in '?'. ("✻" = e2 9c bb, "·" = c2 b7.) The
# no-break space is normalised so the empty-box match is reliable. The timer
# regex is intentionally NOT widened here - unseen verb/format variants are a
# separate concern; this change only handles the timer's ABSENCE.
ends_in_question() {
  local nbsp=$'\xc2\xa0'
  printf '%s\n' "${1//$nbsp/ }" | LC_ALL=C awk '
    { line[NR] = $0 }
    END {
      box = 0
      for (i = NR; i >= 1; i--) if (line[i] ~ /^❯ *$/) { box = i; break }
      hi = (box > 0) ? box - 2 : NR

      timer = 0
      for (i = hi; i >= 1; i--) if (line[i] ~ /✻.*for [0-9]+s *$/) { timer = i; break }

      last = ""
      if (timer > 0) {
        for (i = timer - 1; i >= 1; i--) {
          s = line[i]; sub(/[ \t]+$/, "", s)
          if (s != "") { last = s; break }
        }
      } else {
        for (i = hi; i >= 1; i--) {
          s = line[i]; sub(/[ \t]+$/, "", s)
          t = s; sub(/^[ \t]+/, "", t)
          if (t == "") continue
          if (t ~ /^Tip:/) continue
          if (t ~ / · /) continue
          last = s; break
        }
      }
      exit (last ~ /\?$/) ? 0 : 1
    }
  '
}

# Take one fresh pair of snapshots and classify them. Sets the globals `state`,
# `code`, and the evidence vars (differ/spinner/menu/idle_box/ends_q). Returns
# nonzero if a capture fails. Both the single-shot path and --watch call THIS, so
# the two modes can never drift apart - there is one classifier, not two.
#
# Precedence (liveness is decided BEFORE the menu shape, which is how menu-like text in
# displayed content is kept from firing - GAP-2/3 false-positive, hit live at 14:17):
#   1. a spinner is present                -> busy. A working pane is never a menu, so
#      this is checked first; it vetoes a menu shape sitting in the working pane's text.
#   2. a genuine idle box (the "⏵⏵" mode marker + empty "❯") is authoritative for the
#      settled state, ABOVE the snapshot diff: a real idle box can still show transient
#      boot chrome that makes two snapshots differ (proven against a live session), so
#      the box overrides motion. A live menu has no empty "❯" (its "❯" carries an option
#      number), so a settled box and a menu are mutually exclusive. Inside it, a trailing
#      "?" means question, else idle.
#   3. the snapshots differ                -> busy. An advancing pane is working, not a
#      static menu; deciding this before menu stops streamed numbered-list content from
#      reading as a menu. A real selection menu waits for input, so it is static here.
#   4. a numbered-option menu shape         -> waiting-input. Reached only when the pane
#      is static, not working, and not a settled box - i.e. a genuine live menu.
#   5. nothing to trust                     -> idle (the snapshot-diff idle case).
classify_once() {
  local snap1 snap2
  snap1="$(snapshot)" || return 1
  sleep "$INTERVAL"
  snap2="$(snapshot)" || return 1

  if [ "$snap1" = "$snap2" ]; then differ="false"; else differ="true"; fi
  if has_spinner "$snap2"; then spinner="true"; else spinner="false"; fi
  if has_menu "$snap2"; then menu="true"; else menu="false"; fi
  if is_idle_box "$snap2"; then idle_box="true"; else idle_box="false"; fi
  if ends_in_question "$snap2"; then ends_q="true"; else ends_q="false"; fi

  if [ "$spinner" = "true" ]; then
    state="busy"; code="$EXIT_BUSY"
  elif [ "$idle_box" = "true" ]; then
    if [ "$ends_q" = "true" ]; then
      state="question"; code="$EXIT_QUESTION"
    else
      state="idle"; code="$EXIT_IDLE"
    fi
  elif [ "$differ" = "true" ]; then
    state="busy"; code="$EXIT_BUSY"
  elif [ "$menu" = "true" ]; then
    state="waiting-input"; code="$EXIT_WAITING"
  else
    state="idle"; code="$EXIT_IDLE"
  fi
}

# --watch: poll the pane and print one line per state CHANGE. Emit the first
# read, then stay silent while the state holds. SIGINT/SIGTERM is a clean stop
# (exit 0) - the same trap/exit run_await uses. SIGPIPE is folded into that same
# trap: when a consumer closes the pipe, the next write would otherwise kill the
# process by signal 13 (the linger-then-die mode hit during the #4 gate); the trap
# turns it into a clean exit 0 instead. A failed snapshot - a pane that went away
# mid-watch - makes classify_once return nonzero, and we exit EXIT_WATCH_ERR, the
# same constant single-shot and --await use, so the modes cannot drift. (A silent
# watcher cannot notice a dead reader until its next write; for a consumer that must
# never linger, use --await, which self-terminates.)
run_watch() {
  trap 'exit 0' INT TERM PIPE
  local last="" tick=0
  while :; do
    if ! classify_once; then
      printf 'timmy: capture-pane failed for pane %s\n' "$pane" >&2
      exit "$EXIT_WATCH_ERR"
    fi
    if [ "$state" != "$last" ]; then
      printf '%s %d\n' "$state" "$tick"
      last="$state"
    fi
    tick=$((tick + 1))
  done
}

# --await: read the start state (no output), then block until the state DIFFERS from
# it - print the new state and exit with its code. If --timeout seconds elapse with no
# change, print the (unchanged) current state and exit EXIT_TIMEOUT (a heartbeat). Both
# the start read and each poll call classify_once, so await never drifts from the other
# modes. SIGINT/SIGTERM is a clean stop (exit 0); a failed snapshot exits EXIT_WATCH_ERR.
# Self-terminating - it returns on its own, so nothing lingers (unlike --watch).
run_await() {
  trap 'exit 0' INT TERM
  if ! classify_once; then
    printf 'timmy: capture-pane failed for pane %s\n' "$pane" >&2
    exit "$EXIT_WATCH_ERR"
  fi
  local start_state="$state"
  SECONDS=0
  while [ "$SECONDS" -lt "$timeout" ]; do
    if ! classify_once; then
      printf 'timmy: capture-pane failed for pane %s\n' "$pane" >&2
      exit "$EXIT_WATCH_ERR"
    fi
    if [ "$state" != "$start_state" ]; then
      printf '%s\n' "$state"
      exit "$code"
    fi
  done
  printf '%s\n' "$state"
  exit "$EXIT_TIMEOUT"
}

if [ "$watch" -eq 1 ]; then
  run_watch   # loops until a signal or a capture error; never returns
fi

if [ "$await" -eq 1 ]; then
  run_await   # returns on the first change or at the timeout; never lingers
fi

classify_once || die "capture-pane failed for pane '$pane'"

if [ "$json" -eq 1 ]; then
  printf '{"state":"%s","evidence":{"snapshots_differ":%s,"spinner":%s,"menu":%s,"idle_box":%s,"ends_in_question":%s,"interval":%s}}\n' \
    "$state" "$differ" "$spinner" "$menu" "$idle_box" "$ends_q" "$INTERVAL"
else
  printf '%s\n' "$state"
fi

exit "$code"
